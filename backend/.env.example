# Environment variables for local development
# Copy this file to .env and update values as needed

# Application
APP_NAME=yubi-app-backend
APP_PORT=8000
ENVIRONMENT=development

# Database
DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=airoa
DB_USER=postgres
DB_PASSWORD=postgres

# Sentry (optional - leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0

# Auth
# Shared secret for frontend server -> backend internal auth endpoints.
# Leave empty for local development only.
AUTH_INTERNAL_API_SECRET=

# AWS S3
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=airoa-data
# Presigned URL expiry in seconds (default: 3600 = 1 hour)
S3_PRESIGNED_URL_EXPIRY_SEC=3600

# LocalStack (local development)
# S3_ENDPOINT: backend -> LocalStack (Docker internal network)
S3_ENDPOINT=http://localstack:4566
# S3_PRESIGN_ENDPOINT: URL embedded in presigned URLs (reachable from the browser)
S3_PRESIGN_ENDPOINT=http://localhost:4566

# S3-compatible storage credentials (optional, LocalStack is used for local development)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
